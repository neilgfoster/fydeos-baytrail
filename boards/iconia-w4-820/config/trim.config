# Trim fragment for Acer Iconia W4-820 (Bay Trail-T) — drop built-in driver sets
# this tablet will never use, to cut build time and kernel size. Applied AFTER the
# generic flavour + efi-mixed, then `make olddefconfig` prunes dependents.
#
# KEEP (do NOT disable): DRM_I915, EXT4, SQUASHFS, DM_VERITY, MMC_SDHCI(_ACPI),
# USB_XHCI, EFI_STUB/MIXED, EFI/SIMPLE framebuffer, Bay Trail pinctrl/i2c/AXP288.

# Non-Intel GPUs (this SoC is Intel Gen7 / i915 only)
CONFIG_DRM_NOUVEAU=n
CONFIG_DRM_AMDGPU=n
CONFIG_DRM_RADEON=n
CONFIG_DRM_AST=n
CONFIG_DRM_VMWGFX=n
CONFIG_DRM_QXL=n
CONFIG_DRM_VIRTIO_GPU=n

# Media stack (cameras/TV/DVB) — huge; not needed for bring-up (re-enable later
# if we tackle the camera). Bay Trail atomisp is out of scope for now.
CONFIG_MEDIA_SUPPORT=n

# InfiniBand / RDMA — never on a tablet
CONFIG_INFINIBAND=n
