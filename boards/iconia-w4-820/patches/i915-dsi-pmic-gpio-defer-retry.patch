+		 */
+		int retries = 50;
+
+		do {
+			intel_dsi->gpio_panel = gpiod_get(dev->dev, "panel", flags);
+			if (!IS_ERR(intel_dsi->gpio_panel) ||
+			    PTR_ERR(intel_dsi->gpio_panel) != -EPROBE_DEFER)
+				break;
+			msleep(10);
+		} while (--retries);
 		if (IS_ERR(intel_dsi->gpio_panel)) {
 			drm_err(&dev_priv->drm,
 				"Failed to own gpio for panel control\n");
