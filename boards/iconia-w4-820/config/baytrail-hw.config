# Bay Trail hardware-enablement fragment for the Acer Iconia W4-820.
# Applied on top of kernel-6.6.76-working.config to fix backlight (PMIC PWM),
# i2c/eMMC reliability (shared-bus semaphore), power (PMIC), and to load the
# rootfs's .xz-compressed firmware natively. Append then `make olddefconfig` and
# verify each symbol landed (some deps were disabled by trim.config).

# --- Bay Trail shared-I2C PUNIT semaphore: fixes i2c_designware "timeout waiting
#     for bus ready" (deps IOSF_MBI + I2C_DESIGNWARE_PLATFORM already =y) ---
CONFIG_I2C_DESIGNWARE_BAYTRAIL=y

# --- Regulator + PWM cores (trim.config had disabled these) ---
CONFIG_REGULATOR=y
CONFIG_REGULATOR_FIXED_VOLTAGE=y
CONFIG_PWM=y
CONFIG_PWM_LPSS=y
CONFIG_PWM_LPSS_PLATFORM=y

# --- Crystal Cove PMIC: provides the backlight PWM the panel needs
#     (i915: "Failed to get the PMIC PWM chip") + ACPI power opregion ---
CONFIG_INTEL_SOC_PMIC=y
CONFIG_PWM_CRC=y
CONFIG_PMIC_OPREGION=y
CONFIG_BYTCRC_PMIC_OPREGION=y

# --- AXP288 PMIC stack (belt-and-suspenders for power/charging/regulator on
#     boards that use it instead of / alongside Crystal Cove) ---
CONFIG_MFD_AXP20X=y
CONFIG_MFD_AXP20X_I2C=y
CONFIG_REGULATOR_AXP20X=y
CONFIG_AXP288_ADC=y
CONFIG_AXP288_CHARGER=y
CONFIG_EXTCON_AXP288=y
CONFIG_XPOWER_PMIC_OPREGION=y

# --- Load .xz-compressed firmware natively (rootfs ships only *.xz) so wifi/audio
#     firmware loads without our manual decompress step ---
CONFIG_FW_LOADER_COMPRESS=y
CONFIG_FW_LOADER_COMPRESS_XZ=y
