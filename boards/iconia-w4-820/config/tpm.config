# openFyde ships a software TPM (tpm2-simulator) that exposes itself to the OS via
# the vTPM proxy driver (/dev/vtpmx -> /dev/tpm0). The generic flavour omits it, so
# tpm2-simulator pre-start fails (status 1) -> "TPM not available" -> reboot ~40s in.
# The stock FydeOS kernel enables this via the board overlay.
CONFIG_TCG_VTPM_PROXY=y
