# axp288-power.config — native AXP288 PMIC power-supply drivers.
#
# Why: the board only exposed stale ACPI ADP1/BATC supplies — ADP1/online never
# flips when plugged, so ChromeOS shows no charging bolt, and BATC has no
# charge-control knob for a longevity cap. The real charger is the AXP288 PMIC
# (ACPI INT33FD:00, MFD already bound — axp288_adc works). These leaves add the
# native charger / fuel-gauge / VBUS-extcon that report live state over I2C.
#
# All =m (incl. EXTCON) on purpose: no built-in flips => vmlinuz is unchanged, so
# this ships as hot-loadable modules (depmod + modprobe on-device), NOT a reinject.
# AXP288_CHARGER is otherwise hidden because it depends on EXTCON_AXP288.
CONFIG_EXTCON=m
CONFIG_EXTCON_AXP288=m
CONFIG_AXP288_FUEL_GAUGE=m
CONFIG_AXP288_CHARGER=m
