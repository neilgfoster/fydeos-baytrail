# Board profile: Lenovo ThinkPad 10 (20C1)
# Sourced by scripts/*.sh via --board thinkpad10-20c1

BOARD_ID=thinkpad10-20c1
DEVICE_NAME="Lenovo ThinkPad 10 20C1"
SOC="Intel Atom Z3795 (Bay Trail-T)"
CPU_64BIT=yes                 # 64-bit CPU
FIRMWARE_UEFI_BITNESS=64      # 64-bit UEFI (T3, confirmed via bootmgfw.efi PE machine-type
                               # 8664) -> stock FydeOS boots directly, no EFI_MIXED/bootia32
                               # needed for the main OS. See PROGRESS.md T1/T3.

# openFyde / ChromiumOS build target — same release as the W4-820 final build, since the
# stock installer USB (R144/build 16503, amd64-fydeos_slim-io, kernel 6.6.99) matches it
# exactly (PROGRESS.md T1). Both boards can share ONE ~/openfyde/kernel-6.6 checkout.
CROS_RELEASE=release-R144-16503.B
OPENFYDE_MANIFEST_BRANCH=r144-dev
OPENFYDE_BOARD=amd64-openfyde_slim   # matches installer label amd64-fydeos_slim
KERNEL_SERIES=6.6
KPKG=chromeos-kernel-6_6
KSRC_REL=src/third_party/kernel/v6.6

# No BOOTIA32_URL — 64-bit UEFI does not need the 32-bit GRUB handoff.

# Stock installer kernel this board's USB shipped (for reference / module-version match)
STOCK_KERNEL="6.6.99-g7232af57f054"
STOCK_XLOADFLAGS=0x2b         # irrelevant on 64-bit UEFI (XLF_EFI_HANDOVER_32 not needed
                               # here), recorded for reference only.

# Standalone kernel build (Option A: no cros_sdk). See scripts/build-kernel-standalone.sh
# and scripts/build-rescue-image.sh (rescue/channel-#2 image, this board only).
KERNEL_GIT=https://chromium.googlesource.com/chromiumos/third_party/kernel
KERNEL_BRANCH=release-R144-16503.B-chromeos-6.6
KERNEL_FLAVOUR=chromiumos-x86_64-generic
KERNEL_FAMILY=chromeos

# --- USB/SD facts (T3, PROGRESS.md) — no external boot medium on this board ---
# USB port confirmed permanently dead (physical port/traces, not driver/firmware).
# SD card reader is firmware-invisible (not enumerated by UEFI block I/O).
# Any install/recovery path MUST be entirely eMMC + ESP resident. See PROGRESS.md T3/T4
# and CLAUDE.md's NEVER-BREAK-SSH section.
