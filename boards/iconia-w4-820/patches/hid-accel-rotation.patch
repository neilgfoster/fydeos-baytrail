+	 * ChromeOS iioservice/ash uses it for screen auto-rotation (HID sensors
+	 * otherwise expose no label/location, unlike cros-ec accels). */
+	if (!strcmp(name, "accel_3d")) {
+		indio_dev->label = "accel-display";
+		accel_state->mount_matrix = iconia_accel_mount_matrix;
+	}
+
 	atomic_set(&accel_state->common_attributes.data_ready, 0);
 
 	ret = hid_sensor_setup_trigger(indio_dev, name,
