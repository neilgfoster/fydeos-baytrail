# EFI early console + framebuffer so we can SEE boot on 32-bit-UEFI Bay Trail.
# Stock ChromeOS kernel omits these (relies on i915 KMS only) -> silent boot.
# - SERIAL_8250_CONSOLE selects SERIAL_EARLYCON, which enables EFI_EARLYCON
#   (def_bool) -> `earlycon=efifb` prints the earliest messages.
# - FB_EFI/SYSFB_SIMPLEFB give an i915-independent fbcon console/display so the
#   full kernel log is visible even if i915 hangs.
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_FB=y
CONFIG_FB_EFI=y
CONFIG_SYSFB_SIMPLEFB=y
