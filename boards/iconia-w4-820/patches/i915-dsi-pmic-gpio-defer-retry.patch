@@ -991,7 +992,22 @@ void intel_dsi_vbt_gpio_init(struct intel_dsi *intel_dsi, bool panel_is_on)
 	}
 
 	if (want_panel_gpio) {
-		intel_dsi->gpio_panel = gpiod_get(dev->dev, "panel", flags);
+		/*
+		 * Iconia W4-820: the PMIC "gpio_crystalcove" chip is created a
+		 * few ms after i915 probes (i2c->PMIC->mfd->gpio chain), so the
