# Kernel config fragment for the ThinkPad 10 20C1 RESCUE image (channel #2, see
# PROGRESS.md T4 and /home/neil/.claude/plans/zesty-waddling-fern.md). Merged onto
# `make x86_64_defconfig` by scripts/build-rescue-image.sh's `config` step — deliberately
# NOT the full ChromeOS `chromeos/scripts/prepareconfig` flavour used for the main OS
# kernel; this stays as small as it can while still booting Bay Trail + WiFi + a local
# console. Values below are the union of what boards/iconia-w4-820's known-working config
# enables for the same chip family, plus the local-console additions this rescue image
# needs that the main OS kernel doesn't (framebuffer console, USB HID) — expect to refine
# after the first real-hardware boot test (T4 plan, step 4/5).
#
# CONFIG_INITRAMFS_SOURCE is intentionally NOT set here — it's an absolute build-path,
# injected by build-rescue-image.sh after this fragment is merged.

# --- ACPI / Bay Trail LPSS platform (load-bearing: without these, the SDIO WiFi host
# controller and other LPSS-attached ACPI devices never probe) ---
CONFIG_ACPI=y
CONFIG_ACPI_LEGACY_TABLES_LOOKUP=y
CONFIG_ACPI_TABLE_UPGRADE=y
CONFIG_ACPI_I2C_OPREGION=y
CONFIG_X86_INTEL_LPSS=y
CONFIG_PINCTRL_BAYTRAIL=y
CONFIG_I2C_DESIGNWARE_CORE=y
CONFIG_I2C_DESIGNWARE_PLATFORM=y
CONFIG_I2C_DESIGNWARE_BAYTRAIL=y
CONFIG_I2C_DESIGNWARE_PCI=y

# --- MMC/SDHCI (Bay Trail SDIO WiFi enumerates via sdhci-acpi, not sdhci-pci/pltfm;
# the internal eMMC is a SEPARATE sdhci-acpi instance - same driver covers both) ---
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_IO_ACCESSORS=y
CONFIG_MMC_SDHCI_PCI=y
CONFIG_MMC_SDHCI_ACPI=y

# --- eMMC partition table (GPT, per PROGRESS.md T3) + ESP filesystem (FAT32) - the
# init script mounts the ESP to read/write the persisted rescue password hash ---
CONFIG_EFI_PARTITION=y
CONFIG_VFAT_FS=y
CONFIG_FAT_FS=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y

# --- WiFi (Broadcom SDIO 02D0:4324 / BCM43241, same chip as W4-820). Built IN, not
# modules -> no modprobe/depmod step needed in the initramfs, sidesteps the
# early-coldplug-before-mount trap boards/iconia-w4-820/install/iconia-wifi99-fix.sh hit ---
CONFIG_WIRELESS=y
CONFIG_CFG80211=y
CONFIG_CFG80211_CERTIFICATION_ONUS=y
CONFIG_CFG80211_DEFAULT_PS=y
CONFIG_RFKILL=y
CONFIG_BRCMUTIL=y
CONFIG_BRCMFMAC=y
CONFIG_BRCMFMAC_PROTO_BCDC=y
CONFIG_BRCMFMAC_SDIO=y
# CONFIG_BRCMFMAC_USB is not set
# CONFIG_BRCMFMAC_PCIE is not set

# --- Firmware loader: avoid needing in-initramfs decompression of .xz blobs ---
CONFIG_FW_LOADER=y
CONFIG_FW_LOADER_PAGED_BUF=y
CONFIG_FW_LOADER_COMPRESS=y
CONFIG_FW_LOADER_COMPRESS_XZ=y

# --- EFI (this board is 64-bit UEFI — no EFI_MIXED/HANDOVER_32 needed, unlike the
# 32-bit-UEFI boards config/efi-mixed.config targets) ---
CONFIG_EFI=y
CONFIG_EFI_STUB=y

# --- built-in command line (LOAD-BEARING, found missing after first real-hardware
# boot test came up as a black screen): Windows Boot Manager loads this as a generic
# EFI executable, NOT via a Linux bootloader like GRUB, so it never passes a `console=`
# LoadOptions string the way `linux ... console=tty0` would. Without a built-in cmdline
# the kernel has no console selected at all -> silent black screen (backlight stays on
# since that's independent panel power, not GPU/console activity). Force it here rather
# than relying on any loader to supply one. ---
CONFIG_CMDLINE_BOOL=y
CONFIG_CMDLINE="console=tty0 console=ttyS0,115200n8 fbcon=font:TER16x32"
CONFIG_CMDLINE_OVERRIDE=y

# --- large console font (4th real-hardware attempt: DRM console DID activate -
# "Console: switching to colour frame buffer device 240x75" in dmesg - but 240x75
# characters on a 10" panel is likely far too small to read/notice, which plausibly
# explains "nothing changed" even when input should reach a live tty). Terminus
# 16x32 is the largest built-in bitmap font available. ---
CONFIG_FONT_SUPPORT=y
CONFIG_FONTS=y
CONFIG_FONT_TER16x32=y

# --- text console via DRM (2nd real-hardware attempt, still blank): x86_64_defconfig's
# baseline already pulls in CONFIG_DRM_I915=y (Bay Trail's Gen7 iGPU) - i915 likely takes
# over the display from the EFI GOP framebuffer at init, but CONFIG_DRM_FBDEV_EMULATION
# was off, so there was no fbcon bridge on top of DRM for i915 to draw a text console
# through - nothing to show kernel messages OR our init script's output on, and no
# framebuffer console device for CONFIG_CMDLINE's console=tty0 to bind to either. This
# would explain silence even through a kernel panic (nowhere to render it). ---
CONFIG_DRM_FBDEV_EMULATION=y

# --- initrd / initramfs plumbing ---
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y
CONFIG_RD_XZ=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_TMPFS=y

# --- core networking (busybox udhcpc + wpa_supplicant need these) ---
CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_INET=y

# --- local console: EFI GOP framebuffer text console (light — no real GPU driver;
# same mechanism the UEFI Shell already uses) + USB HID for the folio keyboard, so the
# interactive WiFi/password prompts (T4 plan) work without relying on SSH being up yet ---
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_FB=y
CONFIG_FB_EFI=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_INPUT=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_HID=y
CONFIG_USB_HID=y
CONFIG_HID_GENERIC=y
