# Board profile TEMPLATE — copy this dir to boards/<your-board-id>/ and fill in.
# See docs/adding-a-board.md for the full procedure.

BOARD_ID=CHANGEME               # kebab-case, matches the directory name
DEVICE_NAME="CHANGEME"
SOC="CHANGEME"
CPU_64BIT=yes                   # MUST be yes; a 32-bit CPU cannot run FydeOS's 64-bit kernel
FIRMWARE_UEFI_BITNESS=32        # 32 for the Bay/Cherry Trail case this repo targets

# Build target — pin to the openFyde release whose kernel matches the installer USB.
# Get the kernel version from `inspect-usb.sh` (KVER_A), then find the ChromiumOS
# release-Rxx-XXXX.B carrying that kernel and the matching openFyde <rxx>-dev branch.
CROS_RELEASE=release-RXXX-XXXXX.B
OPENFYDE_MANIFEST_BRANCH=rXXX-dev
OPENFYDE_BOARD=amd64-openfyde_slim   # or the overlay matching the installer label
KERNEL_SERIES=6.6
KPKG=chromeos-kernel-6_6
KSRC_REL=src/third_party/kernel/v6.6

BOOTIA32_URL=https://github.com/hirotakaster/baytail-bootia32.efi/raw/master/bootia32.efi

STOCK_KERNEL="CHANGEME"
STOCK_XLOADFLAGS=CHANGEME
