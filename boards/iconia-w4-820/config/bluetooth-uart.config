# Bluetooth over UART/serdev for the Acer Iconia W4-820 (Bay Trail-T).
# Added Session 20 (2026-07-10) — this is what finally brought up hci0.
#
# The onboard BCM4324B3 BT is a serdev child (ACPI BCM2E3F) of the DesignWare
# LPSS UART (ACPI 80860F0A). Without a serdev host bus + a tty->serdev controller
# there is nothing for the BCM2E3F ACPI node to bind to, so btbcm loads but no
# controller is ever instantiated (the long-standing "no hci0" symptom).
#
# NOTE: SERIAL_DEV_BUS / SERIAL_DEV_CTRL_TTYPORT are bool (=y) => BUILT-IN, so
# changing these forces a vmlinuz rebuild, not just modules. Apply after the base
# config, then `make olddefconfig`. vermagic is unaffected (existing =m modules
# stay compatible). The SCO->HCI routing quirk is a source patch, not a config:
# see patches/bt-sco-transport-routing.patch.

# serdev core (built-in) — the bus + the tty-backed serdev controller
CONFIG_SERIAL_DEV_BUS=y
CONFIG_SERIAL_DEV_CTRL_TTYPORT=y

# Bay Trail LPSS DesignWare UART host (80860F0A -> ttyS0/serial0)
CONFIG_SERIAL_8250_DW=m

# HCI-over-UART with the Broadcom serdev protocol
CONFIG_BT_HCIUART=m
CONFIG_BT_HCIUART_SERDEV=y
CONFIG_BT_HCIUART_BCM=y
CONFIG_BT_HCIUART_H4=y

# Broadcom controller support (btbcm.ko) — usually already =m in the base set
CONFIG_BT_BCM=m
