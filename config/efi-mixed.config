# Kernel config fragment to make a 64-bit FydeOS kernel bootable from 32-bit UEFI
# firmware (Acer Iconia W4-820 / Bay Trail). Merged into the openFyde/ChromiumOS
# kernel config by scripts/build-kernel.sh.
#
# CONFIG_EFI_MIXED builds the 32-bit EFI entry stub, which sets the
# XLF_EFI_HANDOVER_32 bit (0x04) in the kernel's xloadflags (offset 0x236).
# CONFIG_EFI_HANDOVER_PROTOCOL keeps the handover entry that GRUB's `linux`
# loader calls (required on modern kernels where it is a separate option).
CONFIG_EFI_MIXED=y
CONFIG_EFI_HANDOVER_PROTOCOL=y
CONFIG_EFI_STUB=y
