+/* Iconia W4-820: advertise a sampling-frequency list so ChromeOS iioservice will
+ * commit a streaming rate (cros-ec accels expose this; without it iioservice's
+ * buffered reads time out). 10 Hz is the rate the panel-rotation path uses. */
+static const int accel_3d_samp_freq_avail[] = { 10, 0 };
+
+static int accel_3d_read_avail(struct iio_dev *indio_dev,
+			       struct iio_chan_spec const *chan,
+			       const int **vals, int *type, int *length,
+			       long mask)
+{
+	if (chan->type != IIO_ACCEL)
+		return -EINVAL;
+
+	switch (mask) {
+	case IIO_CHAN_INFO_SAMP_FREQ:
+		*vals = accel_3d_samp_freq_avail;
+		*type = IIO_VAL_INT_PLUS_MICRO;
+		*length = ARRAY_SIZE(accel_3d_samp_freq_avail);
+		return IIO_AVAIL_LIST;
+	default:
+		return -EINVAL;
+	}
+}
+
 static const struct iio_info accel_3d_info = {
 	.read_raw = &accel_3d_read_raw,
 	.write_raw = &accel_3d_write_raw,
+	.read_avail = &accel_3d_read_avail,
 };
 
