# Board profile: Acer Iconia W4-820
# Sourced by scripts/*.sh via --board iconia-w4-820

BOARD_ID=iconia-w4-820
DEVICE_NAME="Acer Iconia W4-820"
SOC="Intel Atom Z3740D (Bay Trail-T)"
CPU_64BIT=yes                 # 64-bit CPU -> EFI_MIXED approach is viable
FIRMWARE_UEFI_BITNESS=32      # 32-bit UEFI, no CSM -> needs bootia32 + EFI_MIXED

# openFyde / ChromiumOS build target (see PROGRESS.md for how these were pinned).
# FINAL: committed to R144/6.6.99 in Session 19 to version-match the R144 userland
# (the earlier R138/6.6.76 target caused userspace version skew — see PROGRESS S18).
CROS_RELEASE=release-R144-16503.B
OPENFYDE_MANIFEST_BRANCH=r144-dev
OPENFYDE_BOARD=amd64-openfyde_slim   # matches installer label amd64-fydeos_slim
KERNEL_SERIES=6.6
KPKG=chromeos-kernel-6_6
KSRC_REL=src/third_party/kernel/v6.6

# Prebuilt 32-bit GRUB used for the firmware->bootloader handoff
BOOTIA32_URL=https://github.com/hirotakaster/baytail-bootia32.efi/raw/master/bootia32.efi

# Stock installer kernel this board shipped (for reference / module-version match)
STOCK_KERNEL="6.6.99-fyde-09011-gfdc62122de5f-dirty"
STOCK_XLOADFLAGS=0x2b         # missing 0x04 XLF_EFI_HANDOVER_32 -> the whole problem

# Standalone kernel build (Option A: no cros_sdk). See scripts/build-kernel-standalone.sh
KERNEL_GIT=https://chromium.googlesource.com/chromiumos/third_party/kernel
KERNEL_BRANCH=release-R144-16503.B-chromeos-6.6   # FINAL (R144/6.6.99); both Bay Trail patches apply clean
KERNEL_FLAVOUR=chromiumos-x86_64-generic   # openFyde amd64 flavour; reven has EFI_MIXED, generic doesn't
KERNEL_FAMILY=chromeos
